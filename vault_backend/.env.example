# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Option A — connection string (recommended)
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/vault_db

# Option B — individual fields (used if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vault_db
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_SSL=false        # set to "true" for hosted Postgres (Supabase, Neon, Railway…)

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_128_char_hex_string
JWT_REFRESH_SECRET=replace_with_different_128_char_hex_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── Vault Encryption (AES-256-GCM) ──────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be EXACTLY 64 hex characters (= 32 bytes)
VAULT_ENCRYPTION_KEY=replace_with_64_char_hex_string
