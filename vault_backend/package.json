{
  "name": "vault-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Express + PostgreSQL REST API for my-vault-app",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:migrate": "tsx src/lib/migrate.ts",
